# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Where config.json is stored. Defaults to process.cwd() — in Docker, point
# this at a mounted volume so settings survive container restarts.
DATA_DIR=/data

# ── Admin ─────────────────────────────────────────────────────────────────────
# Optional. If not set, a random password is auto-generated on first boot and
# printed to the container console. You can then change it in the admin panel.
# ADMIN_PASSWORD=

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# These are fallbacks only. Values saved in the admin panel take precedence and
# suppress these env vars (with a one-time console warning explaining why).
JELLYFIN_URL=https://media.yourdomain.com
JELLYFIN_API_KEY=your_jellyfin_api_key_here
JELLYFIN_USER_ID=your_jellyfin_user_id_here

# ── [NON FUNCTIONAL] Upload service ───────────────────────────────────────────
# URL of the companion upload service. Fallback — configure in the admin panel.
UPLOAD_SERVICE_URL=

# ── Discord Activity ──────────────────────────────────────────────────────────
# Required only if using the Discord embedded activity feature.
#
# DISCORD_CLIENT_ID is your numeric Application ID from discord.com/developers.
# It is used at runtime for the server-side token exchange AND must match the
# VITE_DISCORD_CLIENT_ID build arg baked into the client bundle — both values
# must be identical. Change it in docker-compose.yml and rebuild the image.
#
# DISCORD_CLIENT_SECRET can also be set in the admin panel (preferred).
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
