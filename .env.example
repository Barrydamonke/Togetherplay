# Jellyfin (exposed via Cloudflare Tunnel)
JELLYFIN_URL=https://media.yourdomain.com
JELLYFIN_API_KEY=your_jellyfin_api_key_here
JELLYFIN_USER_ID=your_jellyfin_user_id_here

# Upload service (separate Docker container on Unraid, also via Cloudflare Tunnel)
UPLOAD_SERVICE_URL=https://uploads.yourdomain.com

# Set automatically by Railway — no need to set manually
PORT=3000
