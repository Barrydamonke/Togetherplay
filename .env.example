# Admin panel password
ADMIN_PASSWORD=changeme

# Jellyfin (can also be configured through the admin panel)
JELLYFIN_URL=https://media.yourdomain.com
JELLYFIN_API_KEY=your_jellyfin_api_key_here
JELLYFIN_USER_ID=your_jellyfin_user_id_here

# Upload service (optional)
UPLOAD_SERVICE_URL=https://uploads.yourdomain.com

# Discord Activity (required for Discord embedded app support)
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# Port to listen on (default: 3000)
PORT=3000

# Directory where config.json is stored (default: current working directory)
# Set this when running in Docker to point at a mounted volume
DATA_DIR=/data
